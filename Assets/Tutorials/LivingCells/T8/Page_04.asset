  m_Name: Page_04
  m_EditorClassIdentifier: Unity.Tutorials.Core.Editor::Unity.Tutorials.Core.Editor.TutorialPage
  Title:
    m_Untranslated: 
  m_Paragraphs:
    m_Items:
    - m_Type: 0
      Title:
        m_Untranslated: Watch the Flock
      Text:
        m_Untranslated: "Hit <b>Play</b> and observe:\n\n\u2022 Herbivores now <b>move
          in groups</b> \u2014 cluster, align, maintain spacing\n\u2022 When a carnivore
          approaches, the nearest herbivore flees (Repel overrides Flock)\n\u2022
          Flora still wanders independently. Carnivores hunt alone.\n\n<b>The layering:</b>
          Every frame, CellFlocking sets a flock direction. Then CellAgent checks
          for threats. If there's a carnivore (Repel, priority 1), it overrides.
          If not, the flock direction stands.\n\n<b>Experiment:</b>\n\u2022 Set all
          species to Flock with each other\n\u2022 Increase cohesionWeight \u2014
          tighter groups\n\u2022 Increase separationWeight \u2014 more spread out\n\u2022
          Set alignmentWeight to 0 \u2014 cluster without aligning headings"
