  m_Name: Page_04
  m_EditorClassIdentifier: Unity.Tutorials.Core.Editor::Unity.Tutorials.Core.Editor.TutorialPage
  Title:
    m_Untranslated: 
  m_Paragraphs:
    m_Items:
    - m_Type: 0
      Title:
        m_Untranslated: Make Energy Visible
      Text:
        m_Untranslated: 'The cell dies, but we can only see it in the Inspector.
          Let''s add a visual energy bar.


          <b>Steps:</b>

          1.
          Right-click the Cell in Hierarchy > <b>UI > Canvas</b> (becomes a child)

          2.
          Set Render Mode to <b>World Space</b>. Scale it down (0.01, 0.01, 0.01)

          3.
          Inside the Canvas, add <b>UI > Image</b>

          4. Set Image Type to
          <b>Filled</b>, pick a Fill Method (e.g. Horizontal)

          5. Add <b>CellView</b>
          to the Cell root

          6. Wire references: CellLifecycle and the fill
          Image


          <b>The View Rule:</b> CellView reads from CellLifecycle,
          it never writes. Delete every View script and the simulation runs identically.
          Presentation is separate from logic.'
      m_CodeSample: 
